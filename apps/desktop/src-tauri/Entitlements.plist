<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Hardened runtime (required by notarization) blocks microphone access
	     unless this entitlement is present; TCC consent alone is not enough.
	     Screen/system-audio capture (ScreenCaptureKit) needs no entitlement
	     outside the App Store — it is granted via TCC at runtime. -->
	<key>com.apple.security.device.audio-input</key>
	<true/>
</dict>
</plist>

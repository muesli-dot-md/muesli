# ── Internal planning/design notes — not for publication ────────────────────
internal/

# ── Rust ─────────────────────────────────────────────────────────────────────
target/
*.rs.bk

# ── Node / web ───────────────────────────────────────────────────────────────
node_modules/
dist/
build/
.vite/
.svelte-kit/
coverage/
*.tsbuildinfo
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# ── Env & secrets ────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# Google OAuth client (Drive connector) — never commit
muesli.json
# Gitea test-instance token — never commit
gitea.json
test_google_creds.json

# Tauri updater signing key + password — NEVER commit. The public key's
# canonical home is apps/desktop/src-tauri/tauri.conf.json; the human uploads
# the private key/password as GitHub Actions secrets (see apps/desktop/README.md).
apps/desktop/.updater-key
apps/desktop/.updater-key.pass
apps/desktop/.updater-key.pub

# ── Local dev overrides ──────────────────────────────────────────────────────
# Dex OIDC issuer configs stay local so you can tweak them for testing without
# git noise; copy from the tracked dev/*/config.example.yaml templates.
dev/*/config.yaml

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/


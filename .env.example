# Muesli server configuration (ADR 0017: everything via env)
DATABASE_URL=postgres://muesli:muesli@localhost:5433/muesli
MUESLI_LISTEN=127.0.0.1:8787
RUST_LOG=muesli_server=debug,info

# Identity (ADR 0012). Leave OIDC_ISSUER unset for OPEN MODE (local solo: anonymous editors).
# The values below match the dev Dex issuer in docker-compose (login: dev@muesli.md / password).
#OIDC_ISSUER=http://localhost:5556/dex
#OIDC_CLIENT_ID=muesli
#OIDC_CLIENT_SECRET=muesli-dev-secret
#MUESLI_PUBLIC_URL=http://localhost:8787
#MUESLI_WEB_ORIGIN=http://localhost:5173
# Sessions live in Redis when set; in-memory otherwise (lost on restart).
#REDIS_URL=redis://localhost:6380
# Public client id the CLI uses for the device-code flow (default: muesli-cli).
#OIDC_CLI_CLIENT_ID=muesli-cli
# Per-workspace IdP (Phase 5 enterprise, ADR 0012 "Multi-issuer"): no env needed — a
# workspace admin registers additional issuers at runtime via
# PUT /api/workspaces/{id}/sso {issuer, client_id, client_secret, email_domains}.
# Dev: a second Dex plays the corporate IdP (docker compose up -d dex2, issuer
# http://localhost:5558/dex, login corp@corpdomain.example / password); the whole flow
# is driven by apps/web/scripts/enterprise-e2e.mjs. See README "Enterprise".

# Agents over MCP (ADR 0007/0008; POST /mcp).
# MUESLI_AGENT_DIRECT: "auto" (default) downgrades agent mode=direct edits to suggestions
# while a human is co-present in the document; "always" never downgrades; "never" makes
# agents always suggest.
#MUESLI_AGENT_DIRECT=auto
# Off by default: agents may NOT accept suggestions / resolve comments unless the operator
# enables it (the tools return a "policy-disabled" error otherwise).
#MUESLI_AGENT_GATED_ACTIONS=false

# S3-compatible storage backend (ADR 0013). Secrets live ONLY here (env), never in the
# database; per-workspace storage connections (POST /api/workspaces/{id}/storage) hold just
# {endpoint, bucket, region?, prefix?}. The dev values below are the MinIO root credentials
# from docker-compose (docker compose up -d minio minio-init; bucket: muesli-dev).
#MUESLI_S3_ACCESS_KEY=muesli
#MUESLI_S3_SECRET_KEY=muesli-dev-secret

# GitHub-compatible storage backend (ADR 0013, kind "github"): a workspace's git repo on
# GitHub, Gitea, or Forgejo holds the documents via the Contents API. Same secrets posture
# as S3 — the token lives ONLY here; per-workspace connections hold just {api_base, owner,
# repo, branch, prefix?}. api_base is https://api.github.com for GitHub or
# https://<host>/api/v1 for Gitea/Forgejo (dev Gitea from compose: docker compose up -d gitea,
# http://localhost:3300/api/v1, admin muesli / muesli-dev-secret — see docker-compose.yml).
# The token needs repo write scope; the server sends `Authorization: token …`, which
# GitHub, Gitea, and Forgejo all accept.
#MUESLI_GITHUB_TOKEN=

# Google Drive storage backend (ADR 0013, kind "gdrive"): users store documents on their
# OWN Drive and bear their own storage cost. Connections are created per workspace through
# an OAuth dance (GET /api/workspaces/{id}/storage/google/start → Google consent →
# /auth/storage/google/callback), not by POSTing a config. The OAuth web client comes from
# (highest precedence first):
#   1. MUESLI_GOOGLE_CLIENT_ID + MUESLI_GOOGLE_CLIENT_SECRET
#   2. MUESLI_GOOGLE_CLIENT_FILE — a Google "OAuth client" JSON ({"web":{client_id,…}})
#   3. ./muesli.json in the server's cwd, when present (same shape)
# The redirect URI {MUESLI_PUBLIC_URL}/auth/storage/google/callback must be registered on
# the client in the Google Cloud Console (for local testing:
# http://localhost:8787/auth/storage/google/callback).
#MUESLI_GOOGLE_CLIENT_ID=
#MUESLI_GOOGLE_CLIENT_SECRET=
#MUESLI_GOOGLE_CLIENT_FILE=./muesli.json
# Test hooks: endpoint overrides so the whole dance + Drive API can run against a mock
# Google (apps/web/scripts/gdrive-e2e.mjs runs one on :9477). Defaults are the real
# Google endpoints — leave unset in production.
#MUESLI_GOOGLE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
#MUESLI_GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token
#MUESLI_GOOGLE_API_BASE=https://www.googleapis.com

# Out-of-band ingest polls attached objects/files every N seconds (default 20). Polling
# latency is expected behavior on S3, git forges, and Drive (ADR 0013) — external edits
# appear within one interval. MUESLI_S3_POLL_SECS is the legacy name and keeps working.
#MUESLI_STORAGE_POLL_SECS=20

# Production (docker-compose.prod.yml) additionally needs:
#MUESLI_DOMAIN=muesli.example.com
#ACME_EMAIL=you@example.com
#POSTGRES_PASSWORD=change-me
